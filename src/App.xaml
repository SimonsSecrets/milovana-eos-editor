<!-- No StartupUri: App.OnStartup chooses between the GUI and the headless generate-map path. -->
<Application x:Class="MilovanaEosEditor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MilovanaEosEditor">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Brushes.xaml" />
                <ResourceDictionary Source="Themes/Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <local:EnumToBooleanConverter x:Key="EnumToBool" />
            <local:BoolToVisibilityConverter x:Key="BoolToVis" />
            <local:BoolToVisibilityConverter x:Key="BoolToVisInverse" Invert="True" />

            <!-- VM → View wiring. A ContentControl bound to a view-model renders the matching view. -->
            <DataTemplate DataType="{x:Type local:TeaseBrowserViewModel}">
                <local:TeaseBrowserView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type local:ActiveTeaseViewModel}">
                <local:ActiveTeaseView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type local:WorkflowViewModel}">
                <local:WorkflowView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type local:TagImagesViewModel}">
                <local:TagImagesView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type local:ScriptEditorViewModel}">
                <local:ScriptEditorView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
