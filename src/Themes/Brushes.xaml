<!-- Palette lifted from the Claude Design mockup (src/design/Milovana Tease Editor.dc.html).
     Keep these as the single source of colour truth; views reference them by key, never hard-code. -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBrush" Color="#0b6bcb" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#0a5fb5" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#eef4fb" />
    <SolidColorBrush x:Key="AccentSoftBorderBrush" Color="#bcd4f0" />
    <SolidColorBrush x:Key="NavActiveBrush" Color="#eaf1fb" />
    <SolidColorBrush x:Key="NavActiveTextBrush" Color="#0b3d91" />

    <!-- Surfaces / structure -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#f3f3f3" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#ffffff" />
    <SolidColorBrush x:Key="SubtleSurfaceBrush" Color="#fbfbfb" />
    <SolidColorBrush x:Key="HoverSurfaceBrush" Color="#f5f5f5" />
    <SolidColorBrush x:Key="CardBorderBrush" Color="#ececec" />
    <SolidColorBrush x:Key="HeaderBorderBrush" Color="#e6e6e6" />
    <SolidColorBrush x:Key="DividerBrush" Color="#e8e8e8" />
    <SolidColorBrush x:Key="ControlBorderBrush" Color="#dcdcdc" />
    <SolidColorBrush x:Key="GhostBorderBrush" Color="#d2d2d2" />

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1a1a1a" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#444444" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#8a8a8a" />
    <SolidColorBrush x:Key="TextFaintBrush" Color="#9a9a9a" />

    <!-- Status -->
    <SolidColorBrush x:Key="StatusGreenTextBrush" Color="#0a7c46" />
    <SolidColorBrush x:Key="StatusGreenBgBrush" Color="#eef6f0" />
    <SolidColorBrush x:Key="StatusBlueTextBrush" Color="#2b6fd6" />
    <SolidColorBrush x:Key="StatusBlueBgBrush" Color="#eef4fb" />
    <SolidColorBrush x:Key="StatusAmberTextBrush" Color="#9a5b00" />
    <SolidColorBrush x:Key="StatusAmberBgBrush" Color="#fff4e5" />
    <SolidColorBrush x:Key="StatusRedTextBrush" Color="#c42b1c" />
    <SolidColorBrush x:Key="StatusRedBgBrush" Color="#fde7e9" />

</ResourceDictionary>
