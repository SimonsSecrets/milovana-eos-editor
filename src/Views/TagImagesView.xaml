<UserControl x:Class="MilovanaEosEditor.TagImagesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MilovanaEosEditor">
    <!-- Placeholder. The legacy gallery/tagging UI (src/Old/LegacyTaggingView) is migrated here later. -->
    <Border Background="White">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="460">
            <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center"
                       Foreground="{StaticResource TextPrimaryBrush}" />
            <TextBlock Text="{Binding Subtitle}" TextAlignment="Center" TextWrapping="Wrap" Margin="0,10,0,0"
                       FontSize="13.5" Foreground="{StaticResource TextMutedBrush}" />
            <Border CornerRadius="6" Padding="10,4" Margin="0,18,0,0" HorizontalAlignment="Center"
                    Background="{StaticResource AccentSoftBrush}">
                <TextBlock Text="Coming in a follow-up" FontSize="11.5" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}" />
            </Border>
        </StackPanel>
    </Border>
</UserControl>
