<UserControl x:Class="MilovanaEosEditor.WorkflowView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MilovanaEosEditor">

    <UserControl.Resources>

        <!-- "Open" action: soft-blue fill, accent text (navigates to another tool). -->
        <Style x:Key="WorkflowOpenButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#e3eefb" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- "Run" action: solid accent (an automation). Disabled until the backend lands. -->
        <Style x:Key="WorkflowRunButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Hoverable info item: a small "i" badge that surfaces the step explanation on hover. -->
        <Style x:Key="InfoBadge" TargetType="Border">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#cfcfcf" />
            <Setter Property="Cursor" Value="Help" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- One pipeline step row. -->
        <DataTemplate x:Key="WorkflowStepTemplate">
            <Border x:Name="row" BorderBrush="#f4f4f4" BorderThickness="0,0,0,1" Padding="0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="26" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- dot + connecting line -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- current-step glow ring (behind the dot) -->
                        <Ellipse x:Name="glow" Grid.Row="0" Width="34" Height="34" Visibility="Collapsed"
                                 Fill="#260b6bcb" HorizontalAlignment="Center" VerticalAlignment="Center" />

                        <!-- the dot -->
                        <Border x:Name="dot" Grid.Row="0" Width="26" Height="26" CornerRadius="13"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Background="White" BorderThickness="1.5" BorderBrush="#e0e0e0">
                            <TextBlock x:Name="glyph" Text="{Binding Glyph}" FontSize="12" FontWeight="Bold"
                                       Foreground="#bbb" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>

                        <!-- the line down to the next step -->
                        <Rectangle x:Name="line" Grid.Row="1" Width="2" Fill="#e2e2e2"
                                   HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                   Margin="0,5,0,0" MinHeight="8" />
                    </Grid>

                    <!-- title / info / signal -->
                    <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#222" VerticalAlignment="Center" />
                            <Border Style="{StaticResource InfoBadge}" Margin="9,0,0,0"
                                    ToolTip="{Binding Info}" ToolTipService.InitialShowDelay="200"
                                    ToolTipService.ShowDuration="20000">
                                <TextBlock Text="i" FontFamily="Georgia, 'Times New Roman', serif"
                                           FontStyle="Italic" FontSize="11" FontWeight="Bold" Foreground="#9a9a9a"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <Border x:Name="badge" Margin="9,0,0,0" CornerRadius="5" Padding="7,2"
                                    Background="#e7f1fc" VerticalAlignment="Center" Visibility="Collapsed">
                                <TextBlock Text="CURRENT" FontSize="10.5" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBrush}" />
                            </Border>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{Binding Who}" FontSize="12" Foreground="#8a8a8a"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="·" FontSize="12" Foreground="#d0d0d0" Margin="8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="signal" Text="{Binding Signal}" FontSize="12" Foreground="#888"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                    <!-- action button (Open = navigates, Run = disabled placeholder) -->
                    <Grid Grid.Column="2" VerticalAlignment="Center" Margin="12,0,0,0">
                        <Button x:Name="openBtn" Style="{StaticResource WorkflowOpenButton}"
                                Content="{Binding ActionLabel}" Command="{Binding ActionCommand}"
                                Visibility="Collapsed" />
                        <Button x:Name="runBtn" Style="{StaticResource WorkflowRunButton}"
                                Content="{Binding ActionLabel}" IsEnabled="{Binding ActionEnabled}"
                                Visibility="Collapsed" />
                    </Grid>
                </Grid>
            </Border>

            <DataTemplate.Triggers>
                <!-- DONE: green dot with ✓, green line + signal -->
                <DataTrigger Binding="{Binding State}" Value="Done">
                    <Setter TargetName="dot" Property="Background" Value="#1a7f37" />
                    <Setter TargetName="dot" Property="BorderThickness" Value="0" />
                    <Setter TargetName="glyph" Property="Foreground" Value="White" />
                    <Setter TargetName="line" Property="Fill" Value="#1a7f37" />
                    <Setter TargetName="signal" Property="Foreground" Value="{StaticResource StatusGreenTextBrush}" />
                </DataTrigger>

                <!-- CURRENT: blue dot + glow + badge, blue signal -->
                <DataTrigger Binding="{Binding State}" Value="Current">
                    <Setter TargetName="dot" Property="Background" Value="{StaticResource AccentBrush}" />
                    <Setter TargetName="dot" Property="BorderThickness" Value="0" />
                    <Setter TargetName="glow" Property="Visibility" Value="Visible" />
                    <Setter TargetName="badge" Property="Visibility" Value="Visible" />
                    <Setter TargetName="signal" Property="Foreground" Value="{StaticResource AccentBrush}" />
                </DataTrigger>

                <!-- last row: no connecting line -->
                <DataTrigger Binding="{Binding IsLast}" Value="True">
                    <Setter TargetName="row" Property="BorderThickness" Value="0" />
                    <Setter TargetName="line" Property="Fill" Value="Transparent" />
                </DataTrigger>

                <!-- which action button (if any) shows -->
                <DataTrigger Binding="{Binding ActionKind}" Value="Open">
                    <Setter TargetName="openBtn" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ActionKind}" Value="Run">
                    <Setter TargetName="runBtn" Property="Visibility" Value="Visible" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

    </UserControl.Resources>

    <Border Background="{StaticResource AppBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <!-- 1240-wide content column (centred on very wide windows, matching the mockup's margin:auto). -->
            <Grid MaxWidth="1240" Margin="40,30,40,60" HorizontalAlignment="Stretch">
                <StackPanel>

                    <!-- header -->
                    <TextBlock Text="Workflow" FontSize="23" FontWeight="SemiBold" HorizontalAlignment="Left"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Margin="0,6,0,24" FontSize="13.5" Foreground="#6a6a6a"
                               TextWrapping="Wrap" HorizontalAlignment="Left">
                        <Run Text="Pipeline state for " />
                        <Run Text="{Binding Tease.Name, Mode=OneWay}" FontWeight="SemiBold" Foreground="#333" />
                        <Run Text=" — computed from the files on disk, not a stored flag." />
                    </TextBlock>

                    <!-- pipeline: a single star column capped at 820 lets the card FILL the width up to
                         820 and stay left-anchored (HorizontalAlignment=Left would shrink it to content). -->
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MaxWidth="820" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" HorizontalAlignment="Stretch" Background="White"
                                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                                CornerRadius="12" Padding="22,6">
                            <ItemsControl ItemsSource="{Binding Steps}"
                                          ItemTemplate="{StaticResource WorkflowStepTemplate}" />
                        </Border>
                    </Grid>

                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Border>
</UserControl>
