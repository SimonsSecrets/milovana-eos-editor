<Window x:Class="MilovanaEosEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MilovanaEosEditor"
        Title="Milovana Tease Editor"
        Height="800" Width="1280" MinHeight="600" MinWidth="900"
        Background="{StaticResource AppBackgroundBrush}"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">
    <DockPanel>

        <!-- ===================== APP HEADER (not the OS title bar) ===================== -->
        <Border DockPanel.Dock="Top" Height="48" Background="White"
                BorderBrush="{StaticResource HeaderBorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <!-- Only shown while a tease is open: its name + a Switch-back button. -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding HasActiveTease, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ActiveTease.Name}" FontSize="13.5" FontWeight="SemiBold"
                               VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                    <Button Style="{StaticResource SubtleButton}" Command="{Binding SwitchToBrowserCommand}"
                            Margin="12,0,0,0" ToolTip="Back to the tease browser">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="13" Height="13" Stretch="Uniform" Stroke="#444" StrokeThickness="1.5"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                  Data="M2 6 H11 M8.5 3 L11.5 6 L8.5 9 M14 10 H5 M8.5 13 L5.5 10 L8.5 7" />
                            <TextBlock Text="Switch" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===================== BODY (browser OR active-tease editor) ===================== -->
        <ContentControl Content="{Binding Body}" />

    </DockPanel>
</Window>
