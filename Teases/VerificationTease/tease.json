{
  "pages": {
    "start": [
      {
        "say": {
          "label": "<p>Welcome to the <strong>verification tease</strong>. This line is <em>left-aligned</em> and uses a <span style=\"color: #1e88e5\">colored span</span>. It&#39;s here to confirm HTML formatting renders.</p>",
          "align": "left"
        }
      },
      {
        "say": {
          "label": "<p>This line uses the default alignment (center) and Auto timing.</p>"
        }
      },
      {
        "say": {
          "label": "<p>Click to continue &mdash; this one waits for you.</p>",
          "mode": "pause"
        }
      },
      {
        "say": {
          "label": "<p>This line shows for exactly three seconds, then moves on.</p>",
          "mode": "custom",
          "duration": "3s"
        }
      },
      {
        "goto": {
          "target": "030-Audio"
        }
      }
    ],
    "030-Audio": [
      {
        "say": {
          "label": "<p><strong>Audio.</strong> The next clip is a 120&nbsp;BPM metronome at <em>80% volume</em>, played <em>twice</em> (loops&nbsp;2). It is non-background, so it stops when we leave this page.</p>",
          "align": "center",
          "mode": "pause"
        }
      },
      {
        "audio.play": {
          "locator": "file:metronome-120bpm.mp3",
          "volume": 0.8,
          "loops": 2
        }
      },
      {
        "say": {
          "label": "<p>This text appeared <em>instantly</em> &mdash; <strong>audio.play</strong> is non-blocking. Click when ready.</p>",
          "align": "center",
          "mode": "pause"
        }
      },
      {
        "goto": {
          "target": "033-Metronome-1"
        }
      }
    ],
    "033-Metronome-1": [
      {
        "say": {
          "label": "<p><strong>Timed metronome sequence.</strong> Because audio clips <em>layer</em> (a new clip does not stop the old one), each tempo segment lives on its <strong>own page</strong> &mdash; the page switch stops the previous clip, so there are no doubled beats at a transition. Sequence: <em>60&nbsp;BPM for 10s, then 120&nbsp;BPM for 5s, then 60&nbsp;BPM for 5s</em>. Click to begin.</p>",
          "align": "center",
          "mode": "pause"
        }
      },
      {
        "audio.play": {
          "locator": "file:metronome-060bpm.mp3",
          "volume": 0.8,
          "loops": 2
        }
      },
      {
        "say": {
          "label": "<p>&#9834; <strong>60 BPM</strong> &mdash; 10 seconds</p>",
          "align": "center",
          "mode": "instant"
        }
      },
      {
        "timer": {
          "duration": "10s",
          "style": "normal"
        }
      },
      {
        "goto": {
          "target": "033-Metronome-2"
        }
