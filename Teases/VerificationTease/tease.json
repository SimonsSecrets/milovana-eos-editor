    "034-MetronomeLines": [
      {
        "say": {
          "label": "<p><strong>Text paced over a metronome.</strong> A single 60&nbsp;BPM clip runs for 10&nbsp;seconds while a new line of text appears <em>every 2&nbsp;seconds</em> (5 lines). One <strong>audio.play</strong> underneath, then <strong>say</strong>&nbsp;&rarr;&nbsp;<strong>timer</strong> pairs drive the cadence. Click to begin.</p>",
          "align": "center",
          "mode": "pause"
        }
      },
      {
        "audio.play": {
          "locator": "file:metronome-060bpm.mp3",
          "volume": 0.8,
          "loops": 2
        }
      },
      {
        "say": {
          "label": "<p>Feel the first beat settle in&hellip;</p>",
          "align": "center",
          "mode": "instant"
        }
      },
      {
        "timer": {
          "duration": "2s",
          "style": "hidden"
        }
      },
      {
        "say": {
          "label": "<p>Breathe with it &mdash; slow and steady.</p>",
          "align": "center",
          "mode": "instant"
        }
      },
      {
        "timer": {
          "duration": "2s",
          "style": "hidden"
        }
      },
      {
        "say": {
          "label": "<p>Halfway now. Let the rhythm carry you.</p>",
          "align": "center",
          "mode": "instant"
        }
      },
      {
        "timer": {
          "duration": "2s",
          "style": "hidden"
        }
      },
      {
        "say": {
          "label": "<p>Stay with me &mdash; don&#39;t drift.</p>",
          "align": "center",
          "mode": "instant"
        }
      },
      {
        "timer": {
          "duration": "2s",
          "style": "hidden"
        }
      },
      {
        "say": {
          "label": "<p>And&hellip; ease off.</p>",
          "align": "center",
          "mode": "instant"
        }
      },
      {
        "timer": {
          "duration": "2s",
          "style": "hidden"
        }
      },
      {
        "say": {
          "label": "<p>Ten seconds, five lines &mdash; text paced over a continuous metronome. Click to continue.</p>",
          "align": "center",
          "mode": "pause"
