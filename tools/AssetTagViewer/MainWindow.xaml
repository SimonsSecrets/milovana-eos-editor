<Window x:Class="AssetTagViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Asset Tag Viewer" Height="780" Width="1200"
        Closing="OnClosing">
    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="S" Command="ApplicationCommands.Save" />
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Save" Executed="OnSaveCommand" />
    </Window.CommandBindings>

    <DockPanel>
        <ToolBar DockPanel.Dock="Top">
            <Button Content="Open…" Click="OnOpen" />
            <Button Content="Save" Click="OnSave" />
            <Separator />
            <Button Content="◀ Prev" Click="OnPrev" />
            <Button Content="Next ▶" Click="OnNext" />
            <Separator />
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="8,0" />
        </ToolBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <!-- Image list -->
            <ListBox x:Name="ImageList" Grid.Column="0" Margin="6"
                     DisplayMemberPath="Display" SelectionChanged="OnSelectionChanged" />

            <!-- Preview -->
            <Border Grid.Column="1" Margin="6" Background="#222222">
                <Grid>
                    <TextBlock x:Name="NoImageText" Text="(no image)" Foreground="#888888"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Image x:Name="Preview" Stretch="Uniform" StretchDirection="DownOnly" />
                </Grid>
            </Border>

            <!-- Editor -->
            <ScrollViewer Grid.Column="2" Margin="6" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Gallery / file" FontWeight="Bold" />
                    <TextBlock x:Name="WhichText" TextWrapping="Wrap" Margin="0,2,0,10" />

                    <TextBlock Text="Gallery theme (read-only)" FontWeight="Bold" />
                    <TextBlock x:Name="ThemeText" TextWrapping="Wrap" Foreground="#666666"
                               Margin="0,2,0,10" />

                    <TextBlock Text="Subject" FontWeight="Bold" />
                    <ComboBox x:Name="SubjectBox" IsEditable="True"
                              Text="{Binding SelectedItem.Subject, ElementName=ImageList, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                    <TextBlock Text="Pace (1–5, energy/tempo — ignores nudity)" FontWeight="Bold" Margin="0,10,0,0" />
                    <ComboBox x:Name="PaceBox"
                              SelectedItem="{Binding SelectedItem.Pace, ElementName=ImageList, Mode=TwoWay}" />

                    <TextBlock Text="Explicitness" FontWeight="Bold" Margin="0,10,0,0" />
                    <ComboBox x:Name="ExplicitBox" IsEditable="True"
                              Text="{Binding SelectedItem.Explicitness, ElementName=ImageList, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                    <TextBlock Text="Orientation" FontWeight="Bold" Margin="0,10,0,0" />
                    <ComboBox x:Name="OrientationBox" IsEditable="True"
                              Text="{Binding SelectedItem.Orientation, ElementName=ImageList, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                    <TextBlock Text="Notes" FontWeight="Bold" Margin="0,10,0,0" />
                    <TextBox x:Name="NotesBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="100"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding SelectedItem.Notes, ElementName=ImageList, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>
